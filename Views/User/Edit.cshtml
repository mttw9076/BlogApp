@model WebApplication1.Models.ApplicationUser

<h2>Edytuj profil</h2>

<form asp-action="Edit" method="post" enctype="multipart/form-data" class="mt-3">

    <div class="mb-3">
        <label class="form-label">Wyświetlana nazwa</label>
        <input asp-for="DisplayName" class="form-control" />
        <span asp-validation-for="DisplayName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Bio</label>
        <textarea asp-for="Bio" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Bio" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Zdjęcie profilowe</label>
        <input type="file" name="profileImage" class="form-control" />

        @if (!string.IsNullOrEmpty(Model.ProfileImagePath))
        {
            <div class="mt-3">
                <p>Aktualne zdjęcie:</p>
                <img src="@Model.ProfileImagePath" class="img-thumbnail" style="max-width: 200px;" />
            </div>
        }
    </div>

    <button type="submit" class="btn btn-primary">Zapisz</button>
    <a asp-action="Profile" class="btn btn-secondary">Anuluj</a>
</form>
