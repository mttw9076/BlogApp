@model IEnumerable<WebApplication1.Models.Subscription>

@{
    ViewData["Title"] = "Subskrypcje";
}

<h2>Twoje subskrypcje</h2>

@if (!Model.Any())
{
    <p>Nie subskrybujesz jeszcze żadnych użytkowników.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Użytkownik</th>
                <th>Opcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td>@s.TargetUserId</td>
                    <td>
                        <form asp-action="Unsubscribe" method="post">
                            <input type="hidden" name="id" value="@s.Id" />
                            <button class="btn btn-danger btn-sm">Odsubskrybuj</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
